{
    "output_dir": "output",
    "reaper_path": "",
    "midi": {
        "note_interval_semitones": 3,
        "lowest_note": 24,
        "highest_note": 108,
        "note_length_seconds": 3.0,
        "release_tail_seconds": 1.5
    },
    "velocities": [40, 80, 110, 127],
    "audio": {
        "sample_rate": 44100,
        "bit_depth": 24,
        "channels": 2,
        "trim_silence": true,
        "normalize": false,
        "normalize_target_db": -3.0,
        "loop_detection": true,
        "crossfade_loop": true,
        "force_loop": false,
        "verify_pitch": true,
        "auto_length": false,
        "probe_hold_seconds": 6.0,
        "probe_tail_seconds": 8.0
    },
    "render": {
        "worker_threads": 4,
        "resume_after_crash": true
    },
    "exporters": {
        "mpc_xpm": true,
        "sfz": false,
        "kontakt": false,
        "decentsampler": false
    },
    "ui": {
        "theme": "dark",
        "color_theme": "blue"
    }
}
